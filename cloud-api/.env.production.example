# Copy to .env.production on the EC2 instance. Never commit .env.production.

# Used by both the postgres container and the connection URL below.
POSTGRES_PASSWORD=change-me

# "postgres" is the compose service name, reachable on the internal network.
CLOUD_DATABASE_URL=postgresql://vision:change-me@postgres:5432/vision_classifier

# Required by all /detections endpoints as the X-API-Key header.
# Generate with: openssl rand -hex 32
CLOUD_API_KEY=change-me

# Real S3 — no endpoint override, no path-style addressing, no AWS keys.
# Credentials come from the EC2 instance IAM role.
CLOUD_S3_BUCKET=your-detection-image-bucket
CLOUD_S3_PREFIX=detections
AWS_REGION=us-west-1

MAX_IMAGE_BYTES=26214400

# Update when the React frontend has a real origin.
CLOUD_CORS_ORIGINS=http://localhost:5173
