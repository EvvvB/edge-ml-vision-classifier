#!/usr/bin/env python3
"""Seed the cloud API with the motion-crop dog fixtures.

Uploads each frame in tests/fixtures/motion_crops/ with its sidecar
metadata, shaped exactly like a Pi-forwarded motion_crops detection
(inference_mode, inference_rois, fomo/yolo detections). Use it to
exercise the dashboard's motion-crop view without a live Nicla.

Re-running creates new detection rows; each run stamps a fresh
captured_at. Stdlib only:

    bin/seed-motion-crops [--url http://127.0.0.1:8000] [--key API_KEY]
"""
from __future__ import annotations

import argparse
import json
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path
from urllib import error, request

FIXTURES = Path(__file__).resolve().parent.parent / "tests" / "fixtures" / "motion_crops"


def multipart_body(metadata: str, image_name: str, image_bytes: bytes) -> tuple[bytes, str]:
    boundary = uuid.uuid4().hex
    parts = [
        f'--{boundary}\r\nContent-Disposition: form-data; name="metadata"\r\n\r\n'.encode()
        + metadata.encode()
        + b"\r\n",
        f'--{boundary}\r\nContent-Disposition: form-data; name="image"; '
        f'filename="{image_name}"\r\nContent-Type: image/jpeg\r\n\r\n'.encode()
        + image_bytes
        + b"\r\n",
        f"--{boundary}--\r\n".encode(),
    ]
    return b"".join(parts), f"multipart/form-data; boundary={boundary}"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--url", default="http://127.0.0.1:8000", help="cloud API base URL")
    parser.add_argument("--key", default=None, help="X-API-Key value, if the API requires one")
    args = parser.parse_args()

    fixtures = sorted(FIXTURES.glob("*.json"))
    if not fixtures:
        print(f"no fixtures found in {FIXTURES}", file=sys.stderr)
        return 1

    captured_at = datetime.now(timezone.utc).isoformat()
    for metadata_path in fixtures:
        metadata = json.loads(metadata_path.read_text())
        metadata["captured_at"] = captured_at
        image_path = metadata_path.with_suffix(".jpg")

        body, content_type = multipart_body(
            json.dumps(metadata), image_path.name, image_path.read_bytes()
        )
        req = request.Request(
            f"{args.url.rstrip('/')}/detections",
            data=body,
            headers={"Content-Type": content_type},
            method="POST",
        )
        if args.key:
            req.add_header("X-API-Key", args.key)

        try:
            with request.urlopen(req) as response:
                result = json.loads(response.read())
        except error.URLError as exc:
            print(f"{metadata_path.stem}: upload failed: {exc}", file=sys.stderr)
            return 1

        detection = result.get("detection") or result
        print(
            f"{metadata_path.stem}: {detection.get('image_id')} "
            f"({detection.get('upload_status')})"
        )

    return 0


if __name__ == "__main__":
    sys.exit(main())
